{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Auth Switch",
  "identifier": "com.lucifer.codex-auth-switch",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Codex Auth Switch",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": ["icons/icon.png", "icons/icon.icns", "icons/icon.ico"],
    "category": "DeveloperTool",
    "macOS": {
      "bundleVersion": "1",
      "infoPlist": "Info.plist"
    }
  }
}
