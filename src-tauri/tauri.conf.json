{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Auth Switch",
  "identifier": "com.lucifer.codex-auth-switch",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Codex Auth Switch",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "createUpdaterArtifacts": true,
    "icon": ["icons/icon.png", "icons/icon.icns", "icons/icon.ico"],
    "category": "DeveloperTool",
    "macOS": {
      "bundleVersion": "1",
      "infoPlist": "Info.plist",
      "dmg": {
        "background": "icons/dmg-background.png",
        "windowSize": {
          "width": 660,
          "height": 400
        },
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVBQzY5Mzc2NkZGRTMzNzcKUldSM00vNXZkcFBHNmtoVC96RnRzVjRqd3BNUFlpdjFhNERLZE4wWllMTmQvV3Y2WUYvM2RuVXMK",
      "endpoints": []
    }
  }
}
